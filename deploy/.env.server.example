POSTGRES_DB=apprentice_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-db-password

APP_NAME=Apprentice AI API
APP_ENV=production
DEBUG=false
DATABASE_URL=postgresql+asyncpg://postgres:replace-with-a-strong-db-password@db:5432/apprentice_ai
JWT_SECRET=replace-with-a-long-random-secret
TEACHER_REG_CODE=replace-with-a-private-teacher-code
FRONTEND_URL=https://your-domain.example
CORS_ORIGINS=https://your-domain.example
DEEPSEEK_API_KEY=replace-with-your-rotated-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
MOCK_AI_ENABLED=false
AUTO_CREATE_SCHEMA=true
SESSION_SUMMARY_TRIGGER_TURNS=20
SESSION_RECENT_MESSAGES=6
TEST_WORKER_POLL_INTERVAL_SECONDS=2
